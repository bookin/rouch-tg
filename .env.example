# ===========================================
# Application Settings
# ===========================================
APP_NAME="Rouch Karma Manager"
APP_VERSION="0.1.0"
DEBUG=false
ENVIRONMENT=production

# ===========================================
# Frontend Settings
# ===========================================
VITE_API_URL=http://localhost:8000

# ===========================================
# Database (PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://rouch_user:your_secure_password@postgres:5432/rouch
POSTGRES_PASSWORD=your_secure_password
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# ===========================================
# Qdrant Vector Database
# ===========================================
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_SIZE=384
QDRANT_API_KEY=

# ===========================================
# Redis Cache
# ===========================================
REDIS_URL=redis://redis:6379
REDIS_CACHE_TTL=3600
REDIS_QUOTE_CACHE_TTL=86400
REDIS_CORRELATION_CACHE_TTL=7200

# ===========================================
# Telegram Bot
# ===========================================
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_RATE_LIMIT=30
TELEGRAM_MESSAGE_DELAY=0.05
WEBAPP_URL=https://your-domain.com

# ===========================================
# AI / LLM (Multi-provider support: GroqCloud, OpenAI, Gemini, Ollama)
# ===========================================
AI_PROVIDER=groq
AI_API_KEY=your_api_key_here
AI_MODEL=llama-3.1-70b-versatile
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2048
AI_BASE_URL=

# ===========================================
# Knowledge Base
# ===========================================
KNOWLEDGE_BASE_PATH=data/knowledge_base

# ===========================================
# Scheduler Settings
# ===========================================
SCHEDULER_ENABLED=true
SCHEDULER_CHECK_INTERVAL=60

# Morning Messages (user's local time)
MORNING_ENABLED=true
MORNING_HOUR=7
MORNING_MINUTE=30

# Evening Messages (user's local time)
EVENING_ENABLED=true
EVENING_HOUR=21
EVENING_MINUTE=0

# ===========================================
# CORS Settings
# ===========================================
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","https://your-domain.com"]
CORS_ALLOW_CREDENTIALS=true

# ===========================================
# API Settings
# ===========================================
API_PREFIX=/api
DOCS_URL=/docs
REDOC_URL=/redoc

# ===========================================
# Security
# ===========================================
SECRET_KEY=change-this-to-random-string-in-production

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=INFO
